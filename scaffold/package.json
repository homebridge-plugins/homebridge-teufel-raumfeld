    "lint": "eslint src",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "raumfeld",
    "teufel",
    "multiroom",
    "airplay",
    "upnp",
    "openhome"
  ],
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^1.0.3",
    "fast-xml-parser": "^4.4.1",
    "node-ssdp": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.13.0",
    "homebridge": "^1.8.0",
    "nodemon": "^3.1.7",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.10.0"
  },
  "//dependencies-note": "SOAP is hand-rolled over global fetch (see src/raumfeldClient.ts); /getZones XML is parsed with fast-xml-parser. For a production AirPlay path, add an airtunes2 / shairport-sync bridge where src/airplayBridge.ts spawns the receiver.",
