{
  "displayName": "Homebridge Teufel Raumfeld",
  "name": "homebridge-teufel-raumfeld",
  "version": "0.3.2",
  "description": "Control Teufel Raumfeld multiroom speakers from Apple HomeKit, with AirPlay streaming from iOS.",
  "license": "MIT",
  "author": "Alexander Peither",
  "homepage": "https://github.com/AlexPe-Code/homebridge-teufel-raumfeld#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexPe-Code/homebridge-teufel-raumfeld.git"
  },
  "bugs": {
    "url": "https://github.com/AlexPe-Code/homebridge-teufel-raumfeld/issues"
  },
  "type": "module",
  "engines": {
    "homebridge": "^1.8.0 || ^2.0.0",
    "node": "^18.20.0 || ^20.18.0 || ^22.10.0 || ^24.0.0 || ^26.0.0"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "config.schema.json",
    "homebridge-ui",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "rimraf ./dist && tsc",
    "watch": "tsc --watch",
